generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseType {
  COURSE
  TEACHER
  COACH
}

enum OrderStatus {
  PENDING_PAYMENT
  PENDING_USE
  PENDING_REVIEW
  COMPLETED
  CANCELLED
  REFUNDING
  REFUNDED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum MerchantType {
  INSTITUTION
  PERSONAL
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FollowTargetType {
  TEACHER
  INSTITUTION
  COACH
}

model User {
  id        String   @id @default(cuid())
  openid    String   @unique
  unionid   String?
  phone     String?
  nickname  String?
  avatar    String?
  points    Int      @default(0)
  coins     Int      @default(0)
  isMember  Boolean  @default(false)
  growthBalance Decimal @default(0) @db.Decimal(10, 2)
  lastSignInAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartItems            CartItem[]
  orders               Order[]
  enrollments          Enrollment[]
  userCoupons          UserCoupon[]
  browseHistories      BrowseHistory[]
  favorites            Favorite[]
  follows              Follow[]
  appointments         Appointment[]
  addresses            Address[]
  merchantApplications MerchantApplication[]
  invoices             Invoice[]
  bankCards            BankCard[]
}

model Category {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  emoji     String?
  bgColor   String?
  sortOrder Int      @default(0)
  courses   Course[]
}

model Course {
  id              String     @id @default(cuid())
  title           String
  subtitle        String?
  tags            String[]   @default([])
  price           Decimal    @db.Decimal(10, 2)
  originalPrice   Decimal?   @db.Decimal(10, 2)
  coverUrl        String?
  coverBg         String?
  detailImageUrl  String?
  type            CourseType @default(COURSE)
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  city            String?
  district        String?
  address         String?
  storeName       String?
  institutionName String?
  targetAudience  String?
  brandName       String?
  memberPrice     Decimal?   @db.Decimal(10, 2)
  ageRange        String?
  rating          Float?
  enrollCount     Int?
  sales           Int?
  reviewCount     Int        @default(0)
  description     String?
  facilityTags    String[]   @default([])
  serviceTags     String[]   @default([])
  policyTags      String[]   @default([])
  featureTags     String[]   @default([])
  overview        Json?
  syllabus        Json?
  sortOrder       Int        @default(0)
  published       Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  cartItems       CartItem[]
  orderItems      OrderItem[]
  enrollments     Enrollment[]
  browseHistories BrowseHistory[]
  favorites       Favorite[]
  appointments    Appointment[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  quantity  Int      @default(1)
  selected  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
}

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(PENDING_PAYMENT)
  totalAmount Decimal     @db.Decimal(10, 2)
  payAmount   Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]
  enrollments Enrollment[]
}

model OrderItem {
  id       String  @id @default(cuid())
  orderId  String
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courseId String
  course   Course  @relation(fields: [courseId], references: [id])
  quantity Int     @default(1)
  price    Decimal @db.Decimal(10, 2)
}

model Enrollment {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  courseId     String
  course       Course           @relation(fields: [courseId], references: [id])
  orderId      String?
  order        Order?           @relation(fields: [orderId], references: [id])
  status       EnrollmentStatus @default(ACTIVE)
  lessonTotal  Int              @default(8)
  lessonUsed   Int              @default(0)
  nextLessonAt DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Banner {
  id        String  @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String?
  bgStyle   String?
  linkUrl   String?
  sortOrder Int     @default(0)
  active    Boolean @default(true)
}

model Coupon {
  id        String  @id @default(cuid())
  amount    Decimal @db.Decimal(10, 2)
  minAmount Decimal @default(0) @db.Decimal(10, 2)
  title     String?
  newcomer  Boolean @default(false)
  active    Boolean @default(true)

  userCoupons UserCoupon[]
}

model UserCoupon {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  claimed   Boolean  @default(true)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, couponId])
}

model BrowseHistory {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId, viewedAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Follow {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType FollowTargetType
  targetId   String
  targetName String
  targetDesc String?
  createdAt  DateTime         @default(now())

  @@unique([userId, targetType, targetId])
}

model Appointment {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId      String?
  course        Course?           @relation(fields: [courseId], references: [id])
  title         String
  appointmentAt DateTime
  status        AppointmentStatus @default(PENDING)
  remark        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, appointmentAt])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  province  String
  city      String
  district  String
  detail    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MerchantApplication {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        MerchantType
  name        String
  contact     String
  phone       String
  city        String?
  description String?
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Invoice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  taxNo     String?
  email     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BankCard {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankName    String
  cardNoLast4 String
  holderName  String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
