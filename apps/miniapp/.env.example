# Copy to .env. Rebuild miniapp after changes (pnpm dev:weapp).

# 本地 mock（默认）
TARO_APP_API_BASE=http://localhost:3000/api
TARO_APP_USE_MOCK=true

# ECS API（模拟器可勾选「不校验合法域名」；真机图片走小程序包内本地资源映射）
# TARO_APP_API_BASE=http://101.37.14.30:3000/api
# TARO_APP_USE_MOCK=false

# 腾讯位置服务 Key（可选，用于逆地址解析到路/小区；需在公众平台配置 request 合法域名 apis.map.qq.com）
# TARO_APP_QQ_MAP_KEY=
