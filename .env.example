# Copy to .env and fill in values. Never commit .env.

# Local PostgreSQL (Windows native install)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/kpp?schema=public"

# Redis via Docker (docker compose up -d)
REDIS_URL="redis://localhost:6379"

# NestJS
PORT=3000
JWT_SECRET=change-me-in-production

# WeChat mini program (fill when registered)
WECHAT_APPID=
WECHAT_SECRET=

# Taro miniapp — use TARO_APP_ prefix for client env vars
TARO_APP_API_BASE=http://localhost:3000/api
TARO_APP_USE_MOCK=true
