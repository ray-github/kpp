# Copy to .env on ECS: cp .env.production.example .env
# Never commit .env

# PostgreSQL (ECS 本机，用户 postgres，库 kpp)
# 密码含 !@# 等特殊字符时必须 URL 编码，例如 ! → %21
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/kpp?schema=public"

# Redis (ECS 本机 apt 安装)
REDIS_URL="redis://127.0.0.1:6379"

PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

WECHAT_APPID=
WECHAT_SECRET=
