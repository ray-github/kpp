# Copy to .env on ECS: cp .env.production.example .env
# Never commit .env
#
# Prisma / seed 会依次读取：
#   1) /opt/kpp/.env（monorepo 根目录）
#   2) /opt/kpp/apps/api/.env（可选，覆盖根配置）
# 生产环境只需维护根目录 .env 即可。

# PostgreSQL (ECS 本机，用户 postgres，库 kpp)
# 密码含 !@# 等特殊字符时必须 URL 编码，例如 ! → %21
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/kpp?schema=public"

# Redis (ECS 本机 apt 安装)
REDIS_URL="redis://127.0.0.1:6379"

PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

WECHAT_APPID=
WECHAT_SECRET=
